{
  "name": "rpg-game",
  "version": "1.0.0",
  "description": "2d rpg game",
  "keywords": [
    "rpg",
    "games",
    "2d",
    "world"
  ],
  "author": "darryj",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"tsc --watch\" \"live-server --port=3000 --open=./ --wait=500\"",
    "lint": "eslint *.ts scripts/*.ts",
    "lint:fix": "eslint *.ts scripts/*.ts --fix",
    "format": "prettier --write \"*.ts\" \"scripts/*.ts\" \"*.html\" \"*.json\"",
    "format:check": "prettier --check \"*.ts\" \"scripts/*.ts\" \"*.html\" \"*.json\"",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "live-server": "^1.2.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
